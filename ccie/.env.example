# Copy to ccie/.env and fill in your keys (ccie/.env is gitignored)

# Required for real web search (News Scout + Product Tracker)
TAVILY_API_KEY=tvly-...

# Enable Tavily instead of mocks
ENV=prod
USE_MOCK_TOOLS=0

# Optional — classify, discover, SWOT
# OPENAI_API_KEY=sk-...

# Optional
# WEAVE_DISABLED=1
# REDIS_URL=redis://localhost:6379/0
