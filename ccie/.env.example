# Copy to ccie/.env and fill in your keys (ccie/.env is gitignored)

# Required for real web search (News Scout + Product Tracker)
TAVILY_API_KEY=tvly-...

# Enable Tavily instead of mocks
ENV=prod
USE_MOCK_TOOLS=0

# Recommended — smarter classify, competitor discovery, SWOT, landscape summary
OPENAI_API_KEY=sk-...

# W&B Weave observability (remove WEAVE_DISABLED to enable tracing)
WANDB_API_KEY=...
WEAVE_PROJECT=ccie-agents
# WEAVE_DISABLED=1

# P2 auto-score on every agent run (playground + server)
CCIE_AUTO_SCORE=1
CCIE_STALE_NEWS_DAYS=90
CCIE_FRESHNESS_WINDOW_DAYS=90
# CCIE_AUTO_APPLY_WEAVE_SCORERS=1

# Optional
# REDIS_URL=redis://localhost:6379/0
